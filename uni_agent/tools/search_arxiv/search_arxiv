#!/usr/bin/env python3
"""
Description: Search recent arXiv papers and return candidate papers with abstracts.

Parameters:
  --query (string, required): Topic or keyword query.
  --max_results (int, optional): Number of candidate papers to return. Default is 8.
  --days (int, optional): Only keep papers from the last N days. Default is 180.
"""

import argparse
import re
import sys
import urllib.parse
import urllib.request
import xml.etree.ElementTree as ET
from datetime import datetime, timedelta, timezone

ARXIV_API_URL = "http://export.arxiv.org/api/query?search_query=all:{query}&start=0&max_results={max_results}&sortBy=lastUpdatedDate&sortOrder=descending"
DEFAULT_TIMEOUT = 20
MAX_ABSTRACT_LENGTH = 3000
MAX_SEARCH_CANDIDATES = 24
ATOM_NS = {"atom": "http://www.w3.org/2005/Atom"}


def normalize_text(value: str | None) -> str:
    if not value:
        return ""
    value = re.sub(r"\s+", " ", value)
    return value.strip()


def fetch_feed(query: str, max_results: int) -> str:
    url = ARXIV_API_URL.format(query=urllib.parse.quote_plus(query), max_results=max_results)
    request = urllib.request.Request(
        url,
        headers={
            "User-Agent": "uni-agent-search-arxiv/1.0 (+https://github.com/yyDing1/uni-agent)",
        },
    )
    with urllib.request.urlopen(request, timeout=DEFAULT_TIMEOUT) as response:
        return response.read().decode("utf-8", errors="replace")


def parse_datetime(value: str | None) -> datetime | None:
    if not value:
        return None
    return datetime.strptime(value, "%Y-%m-%dT%H:%M:%SZ").replace(tzinfo=timezone.utc)


def parse_entry(entry: ET.Element) -> dict[str, str] | None:
    title = normalize_text(entry.findtext("atom:title", default="", namespaces=ATOM_NS))
    summary = normalize_text(entry.findtext("atom:summary", default="", namespaces=ATOM_NS))
    published = normalize_text(entry.findtext("atom:published", default="", namespaces=ATOM_NS))
    updated = normalize_text(entry.findtext("atom:updated", default="", namespaces=ATOM_NS))
    entry_id = normalize_text(entry.findtext("atom:id", default="", namespaces=ATOM_NS))
    authors = [
        normalize_text(author.findtext("atom:name", default="", namespaces=ATOM_NS))
        for author in entry.findall("atom:author", ATOM_NS)
    ]

    pdf_url = ""
    for link in entry.findall("atom:link", ATOM_NS):
        if link.attrib.get("title") == "pdf":
            pdf_url = link.attrib.get("href", "")
            break

    if not title or not entry_id:
        return None

    return {
        "title": title,
        "summary": summary[:MAX_ABSTRACT_LENGTH],
        "published": published,
        "updated": updated,
        "authors": ", ".join(author for author in authors if author) or "(unknown authors)",
        "abs_url": entry_id,
        "pdf_url": pdf_url or "(no pdf url)",
    }


def filter_recent_papers(papers: list[dict[str, str]], days: int) -> list[dict[str, str]]:
    cutoff = datetime.now(timezone.utc) - timedelta(days=max(days, 1))
    filtered = []
    for paper in papers:
        updated_at = parse_datetime(paper.get("updated"))
        if updated_at is None or updated_at >= cutoff:
            filtered.append(paper)
    return filtered


def format_papers(query: str, papers: list[dict[str, str]], days: int) -> str:
    lines = [
        f"arXiv query: {query}",
        f"Recent window (days): {days}",
        f"Candidate paper count: {len(papers)}",
    ]
    if not papers:
        lines.append("No recent papers found.")
        return "\n".join(lines)

    lines.append("")
    for idx, paper in enumerate(papers, start=1):
        lines.append(f"[{idx}] {paper['title']}")
        lines.append(f"Authors: {paper['authors']}")
        lines.append(f"Published: {paper['published']}")
        lines.append(f"Updated: {paper['updated']}")
        lines.append(f"Abstract URL: {paper['abs_url']}")
        lines.append(f"PDF URL: {paper['pdf_url']}")
        lines.append(f"Abstract: {paper['summary'] or '(no abstract)'}")
        if idx != len(papers):
            lines.append("")
    return "\n".join(lines)


def main():
    parser = argparse.ArgumentParser(description="Search recent arXiv papers and return candidate abstracts.")
    parser.add_argument("--query", required=True, type=str, help="Topic or keyword query")
    parser.add_argument("--max_results", type=int, default=8, help="Number of candidate papers to return")
    parser.add_argument("--days", type=int, default=180, help="Only keep papers updated within the last N days")
    args = parser.parse_args()

    max_results = max(1, args.max_results)
    search_limit = max(max_results * 3, MAX_SEARCH_CANDIDATES)
    try:
        feed_text = fetch_feed(args.query, max_results=search_limit)
        root = ET.fromstring(feed_text)
        entries = root.findall("atom:entry", ATOM_NS)
        papers = [paper for paper in (parse_entry(entry) for entry in entries) if paper is not None]
        papers = filter_recent_papers(papers, days=args.days)
        papers = papers[:max_results]
        print(format_papers(args.query, papers, days=args.days))
    except Exception as exc:
        print(f"search_arxiv failed for query: {args.query}")
        print(f"Reason: {exc}")
        sys.exit(1)


if __name__ == "__main__":
    main()
